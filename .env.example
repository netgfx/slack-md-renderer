# Slack credentials (required) — from https://api.slack.com/apps
# Bot User OAuth Token, starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-token-here
# Signing Secret from Basic Information -> App Credentials
SLACK_SIGNING_SECRET=your-signing-secret-here

# Render.com injects PORT automatically; locally defaults to 3000.
PORT=3000

# When "false" (default), remote <img> tags have their src stripped in the HTML
# export to prevent exfiltration beacons. Set "true" to allow remote images.
ALLOW_REMOTE_IMAGES=false

# OPTIONAL, entry point 3 (file_shared handling). Requires the file_shared event
# subscription and the app to be a member of the listed channels.
#   FILE_SHARED_MODE: off (default) | auto | button
#     auto   = automatically render a shared .md as a threaded reply (renders tables)
#     button = post a "Render" button beneath the shared file
#   FILE_RENDER_CHANNELS: comma-separated channel IDs (NOT names, e.g. C0123ABCD)
#     the feature is active in. Empty = OFF (safety). Use "*" for ALL channels the
#     bot is in (file_shared only fires where the bot is a member).
FILE_SHARED_MODE=off
FILE_RENDER_CHANNELS=
